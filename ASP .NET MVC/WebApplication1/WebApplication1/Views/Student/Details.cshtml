@model WebApplication1.Models.Student

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-info text-white">
                    <h3 class="mb-0">Student Details</h3>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">ID</dt>
                        <dd class="col-sm-8">@Model.Id</dd>

                        <dt class="col-sm-4">Name</dt>
                        <dd class="col-sm-8">@Model.Name</dd>

                        <dt class="col-sm-4">Department ID</dt>
                        <dd class="col-sm-8">@Model.DepartmentId</dd>
                    </dl>
                </div>
                <div class="card-footer bg-white d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4">Edit</a>
                </div>
                <hr />
                <h4 class="mt-4 text-primary">Student Courses & Grades</h4>
                @if (Model.StudentCourses != null && Model.StudentCourses.Any())
                {
                    <table class="table table-sm table-bordered mt-3">
                        <thead class="table-light">
                            <tr>
                                <th>Course Name</th>
                                <th>Degree</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sc in Model.StudentCourses)
                            {
                                <tr>
                                    <td>@sc.Course.Title</td>
                                    <td><span class="badge bg-success">@sc.Degree</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-warning mt-3">This student hasn't been graded in any courses yet.</div>
                }
            </div>
        </div>
    </div>
</div>