@model WebApplication1.Models.Student

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="alert alert-danger shadow" role="alert">
                <h4 class="alert-heading">Are you sure you want to delete this student?</h4>
                <hr>
                <dl class="row mb-0">
                    <dt class="col-sm-4">ID:</dt>
                    <dd class="col-sm-8">@Model.Id</dd>

                    <dt class="col-sm-4">Name:</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4">Department ID:</dt>
                    <dd class="col-sm-8">@Model.DepartmentId</dd>
                </dl>
            </div>

            <div class="d-flex justify-content-between mt-3">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger px-4">Confirm Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>